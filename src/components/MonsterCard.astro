---
interface Monster {
  id: string;
  name: string;
  type: string;
  species?: string;
  image: string;
  icon: string;
  description: string;
  elements?: string[];
  weaknesses?: string[];
  resistances?: string[];
  ailments?: string[];
  sizes?: string[];
  order: number;
  slug?: string;
  games: Record<string, {
    rank: string[];
    habitats?: string[];
    is_dlc?: boolean;
  }>;
}

interface Props {
  monster: Monster;
}

const { monster } = Astro.props;

const baseUrl = import.meta.env.BASE_URL;

// Helper functions
function getMonsterTypeIcon(type: string): string {
  const typeIcons: Record<string, string> = {
    "elder-dragon": "🐉",
    "fanged-beast": "🐺",
    "flying-wyvern": "🦅",
    "brute-wyvern": "🦖",
    leviathan: "🐍",
    "piscine-wyvern": "🐟",
    "bird-wyvern": "🐦",
    carapaceon: "🦀",
    neopteron: "🦋",
    temnoceran: "🕷️",
    skavern: "🦂",
    "fanged-wyvern": "🐺",
  };
  return typeIcons[type] || "🐉";
}

function getMonsterTypeName(type: string): string {
  const typeNames: Record<string, string> = {
    "elder-dragon": "Elder Dragon",
    "fanged-beast": "Fanged Beast",
    "flying-wyvern": "Flying Wyvern",
    "brute-wyvern": "Brute Wyvern",
    leviathan: "Leviathan",
    "piscine-wyvern": "Piscine Wyvern",
    "bird-wyvern": "Bird Wyvern",
    carapaceon: "Carapaceon",
    neopteron: "Neopteron",
    temnoceran: "Temnoceran",
    skavern: "Skavern",
    "fanged-wyvern": "Fanged Wyvern",
  };
  return typeNames[type] || type;
}

function getRankLabel(ranks: string[]): string {
  const rankIcons: Record<string, string> = {
    low: "⭐",
    high: "⭐⭐",
    master: "⭐⭐⭐",
    event: "🎉",
  };
  return ranks.map(r => rankIcons[r] || "").join(" ");
}

function getAvailableGames(games: Record<string, any>): string {
  return Object.keys(games).join(", ");
}
---

<div class="column monster-card-wrapper" data-monster-id={monster.id}>
  <a href={`/monstro/${monster.id}`} class="monster-card">
    <div class="card">
      <div class="card-image">
        <figure class="image is-9by16">
          <img
            src={`${baseUrl}${monster.image}`} alt={monster.name}
          />
        </figure>
      </div>
      <div class="card-content">
        <div class="media">
          <div class="media-left">
            <figure class="image is-48x48">
              {getMonsterTypeIcon(monster.type)}
            </figure>
          </div>
          <div class="media-content">
            <h3 class="title is-4">{monster.name}</h3>
            <p>{getMonsterTypeName(monster.type)}</p>
            <p class="is-size-7 has-text-grey">
              {getRankLabel(Object.values(monster.games).flatMap((g: any) => g.rank))}
            </p>
            <p class="is-size-7 has-text-info">{getAvailableGames(monster.games)}</p>
          </div>
        </div>
      </div>
    </div>
  </a>
</div>
