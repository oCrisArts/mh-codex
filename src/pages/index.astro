---
import Layout from '../layouts/Layout.astro';
import monstersDataRaw from '../data/monsters.json';
import Navigation from '../components/Navigation.astro';
import Header from '../components/Header.astro';
import MonsterCard from '../components/MonsterCard.astro';
import FilterPanel from '../components/FilterPanel.astro';

// Type definition for monster
interface Monster {
  id: number;
  name: string;
  rank: 'low-rank' | 'high-rank' | 'master-rank' | 'arch-tempered' | 'terras-guias';
  type: string;
  weaknesses: string[];
  recommendedGlaive: string;
  materials: string[];
  description: string;
  stats: {
    health: string;
    attack: string;
    defense: string;
  };
  habitat: string[];
  behavior: string[];
  image?: string;
  icon?: string;
}

const monsters = monstersDataRaw as Monster[];
---

<Layout title="Monster Hunter Codex">
  <main class="dshunter-home">
    <!-- Background -->
    <div class="dshunter-bg-container">
      <div class="dshunter-bg-fill"></div>
      <div class="dshunter-bg-video"></div>
    </div>

    <!-- Header -->
    <Header />

    <!-- Navigation -->
    <Navigation />

    <!-- Monster Cards Grid -->
    <section class="dshunter-article" aria-label="Lista de monstros">
      {monsters.map((monster) => (
        <MonsterCard monster={monster} />
      ))}
    </section>

    <!-- Filter Panel -->
    <FilterPanel />
  </main>
</Layout>

<style>
  @import '../styles/main.scss';
</style>

<script>
  // Filter panel functionality
  const filterToggle = document.querySelector('.dshunter-filter-btn');
  const filterPanel = document.getElementById('filterPanel');
  const panelClose = document.getElementById('panelClose');
  const overlay = document.querySelector('.dshunter-overlay');

  // State
  let selectedRank = 'all';

  // Initialize
  document.addEventListener('DOMContentLoaded', () => {
    setupEventListeners();
  });

  // Setup event listeners
  function setupEventListeners() {
    // Filter panel toggle
    filterToggle?.addEventListener('click', openFilterPanel);
    panelClose?.addEventListener('click', closeFilterPanel);
    overlay?.addEventListener('click', closeFilterPanel);

    // Rank filter options
    const rankOptions = document.querySelectorAll('input[name="rank"]');
    rankOptions.forEach(option => {
      option.addEventListener('change', (e) => {
        selectedRank = (e.target as HTMLInputElement).value;
        performSearch();
      });
    });

    // Search functionality
    const searchBar = document.querySelector('.dshunter-search-bar');
    searchBar?.addEventListener('click', () => {
      const searchTerm = prompt('Buscar monstro:');
      if (searchTerm) {
        performSearchByName(searchTerm);
      }
    });
  }

  // Filter panel controls
  function openFilterPanel() {
    filterPanel?.classList.add('open');
    overlay?.classList.add('show');
  }

  function closeFilterPanel() {
    filterPanel?.classList.remove('open');
    overlay?.classList.remove('show');
  }

  // Perform search by rank
  function performSearch() {
    let filteredMonsters = monsters;

    // Filter by rank
    if (selectedRank !== 'all') {
      filteredMonsters = filteredMonsters.filter(monster => 
        monster.rank === selectedRank
      );
    }

    renderMonsters(filteredMonsters);
  }

  // Perform search by name
  function performSearchByName(searchTerm: string) {
    const filteredMonsters = monsters.filter(monster => 
      monster.name.toLowerCase().includes(searchTerm.toLowerCase())
    );
    renderMonsters(filteredMonsters);
  }

  // Render monsters
  function renderMonsters(monstersList: typeof monsters) {
    const article = document.querySelector('.dshunter-article');
    if (!article) return;

    article.innerHTML = monstersList.map(monster => `
      <a href="/monstro?id=${monster.id}" class="dshunter-card">
        <!-- Card Header -->
        <div class="dshunter-card-header">
          <div class="dshunter-card-title">
            <h3>${monster.name}</h3>
          </div>
          <div class="dshunter-card-icon">
            <div class="dshunter-icon-wrapper">
              <img src="${monster.image || '/imgs/monsters/placeholder.jpg'}" alt="${monster.name}" />
            </div>
          </div>
        </div>

        <!-- Card Footer -->
        <div class="dshunter-card-footer">
          <div class="dshunter-card-type">
            <div class="dshunter-type-icon">${getMonsterTypeIcon(monster.type)}</div>
            <div class="dshunter-type-name">${getMonsterTypeName(monster.type)}</div>
          </div>
        </div>

        <!-- Card Image Background -->
        <div class="dshunter-card-image">
          <div class="dshunter-image-filter"></div>
          <div class="dshunter-image-wrapper">
            <img src="${monster.image || '/imgs/monsters/placeholder.jpg'}" alt="${monster.name}" />
          </div>
        </div>
      </a>
    `).join('');
  }

  // Helper functions
  function getMonsterTypeIcon(type: string): string {
    const typeIcons: Record<string, string> = {
      'elder-dragon': '',
      'fanged-beast': '',
      'flying-wyvern': '',
      'brute-wyvern': '',
      'leviathan': '',
      'piscine-wyvern': '',
      'bird-wyvern': '',
      'carapaceon': '',
      'neopteron': '',
      'temnoceran': '',
      'skavern': ''
    };
    return typeIcons[type] || '';
  }

  function getMonsterTypeName(type: string): string {
    const typeNames: Record<string, string> = {
      'elder-dragon': 'Elder Dragon',
      'fanged-beast': 'Fanged Beast',
      'flying-wyvern': 'Flying Wyvern',
      'brute-wyvern': 'Brute Wyvern',
      'leviathan': 'Leviathan',
      'piscine-wyvern': 'Piscine Wyvern',
      'bird-wyvern': 'Bird Wyvern',
      'carapaceon': 'Carapaceon',
      'neopteron': 'Neopteron',
      'temnoceran': 'Temnoceran',
      'skavern': 'Skavern'
    };
    return typeNames[type] || 'Elder Dragon';
  }
</script>
