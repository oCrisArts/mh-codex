---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import Navigation from "../components/Navigation.astro";
import Header from "../components/Header.astro";
import MonsterCard from "../components/MonsterCard.astro";
import FilterPanel from "../components/FilterPanel.astro";

// Get all monsters from collection
const allEntries = await getCollection("monsters");

// Simple mapping - avoid complex operations
const monsters = allEntries.map((entry: any) => ({
  id: entry.data.id,
  name: entry.data.name,
  type: entry.data.type,
  species: entry.data.species,
  image: entry.data.image,
  icon: entry.data.icon,
  description: entry.data.description,
  order: entry.data.order || 0,
  games: entry.data.games || {},
  slug: entry.slug,
}));

// Ordenar
monsters.sort((a: any, b: any) => {
  if (a.order !== b.order) return a.order - b.order;
  return a.name.localeCompare(b.name);
});

// Simple extraction
const gameSet = new Set<string>();
const rankSet = new Set<string>();

for (const m of monsters) {
  for (const game of Object.keys(m.games)) {
    gameSet.add(game);
  }
  for (const gameData of Object.values(m.games)) {
    if ((gameData as any).rank) {
      for (const r of (gameData as any).rank) {
        rankSet.add(r);
      }
    }
  }
}

const availableGames = Array.from(gameSet);
const availableRanks = Array.from(rankSet);
---

<Layout title="Monster Hunter Codex">  
  <Navigation />
  <Header />
  <FilterPanel games={availableGames} ranks={availableRanks} />
  <main class="dshunter-home">
    <section class="section dshunter-article container  is-fluid" aria-label="Lista de monstros">
      <div class="columns is-multiline" id="monster-grid">
        {monsters.map((monster) => (
          <MonsterCard monster={monster} />
        ))}
      </div>
    </section>
  </main>
</Layout>

<style lang="scss">
  @import "../styles/main.scss";
</style>
