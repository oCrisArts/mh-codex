---
import Layout from '../layouts/Layout.astro';
import { getMonsterById } from '../data/monsters.ts';

// Get monster ID from URL
const url = new URL(Astro.request.url);
const monsterId = url.searchParams.get('id');

// Get monster data
const monster = monsterId ? getMonsterById(parseInt(monsterId)) : null;

// If no monster found, redirect to search page
if (!monster) {
	return Astro.redirect('/');
}
---

<Layout title={`Monster Hunter Codex - ${monster.name}`}>
	<div class="monster-page">
		<nav class="navbar" role="navigation" aria-label="Navegação principal">
			<div class="container">
				<div class="navbar-content">
					<div class="search-bar">
						<input 
							type="search" 
							value={monster.name}
							placeholder="Encontrar monstro" 
							aria-label="Pesquisar monstro"
							class="search-input"
							readonly
						/>
						<button class="search-button" aria-label="Pesquisar">
							<span class="material-symbols-outlined">search</span>
						</button>
					</div>
					
					<button class="filter-button" aria-label="Filtros">
						<span class="material-symbols-outlined">filter</span>
						<span>Filtros</span>
					</button>
					
					<div class="brand">
						<img 
							src="https://www.figma.com/api/mcp/asset/dc0160a0-a4c1-4b5f-bf24-c40e1471873d" 
							alt="Monster Hunter Codex"
							width="267"
							height="200"
						/>
					</div>
				</div>
			</div>
		</nav>

		<main class="monster-content" role="main">
			<div class="container">
				<div class="monster-layout">
					<!-- Left Column -->
					<div class="monster-left-column">
						<header class="monster-header">
							<div class="monster-icon-large">
								<img 
									src="https://www.figma.com/api/mcp/asset/3e7fd4b7-948e-4fb1-a65b-72615d4643f5" 
									alt={`Ícone do ${monster.name}`}
									width="140"
									height="140"
								/>
							</div>
							<div class="monster-title-section">
								<h1 class="monster-title">{monster.name}</h1>
							</div>
						</header>

						<div class="monster-description">
							<p>{monster.description}</p>
						</div>

						<div class="monster-image-section">
							<img 
								src={monster.image || 'https://www.figma.com/api/mcp/asset/e655ce98-4898-493b-8bfa-afb85850d1ff'} 
								alt={monster.name}
								class="monster-main-image"
							/>
						</div>

						<div class="monster-tags">
							<div class="monster-type-tag">
								<span class="type-icon"></span>
								<span class="type-name">Brute</span>
							</div>
						</div>
					</div>

					<!-- Right Column -->
					<div class="monster-right-column">
						<div class="tabs-container">
							<div class="tabs" role="tablist">
								<button 
									class="tab is-active" 
									data-tab="physiology"
									role="tab"
									aria-selected="true"
									aria-controls="tab-content"
								>
									Physiology
								</button>
								<button 
									class="tab" 
									data-tab="habitat"
									role="tab"
									aria-selected="false"
									aria-controls="tab-content"
								>
									Habitat
								</button>
								<button 
									class="tab" 
									data-tab="behavior"
									role="tab"
									aria-selected="false"
									aria-controls="tab-content"
								>
									Behavior
								</button>
								<button 
									class="tab" 
									data-tab="materials"
									role="tab"
									aria-selected="false"
									aria-controls="tab-content"
								>
									Materials
								</button>
							</div>

							<div class="tab-content" id="tab-content" role="tabpanel">
								<!-- Physiology Tab Content (Default) -->
								<div class="tab-pane is-active" data-tab-content="physiology">
									<div class="monster-info-item">
										<span class="info-icon"></span>
										<div class="info-details">
											<div class="info-title">{monster.name}</div>
											<div class="info-subtitle">Elder Dragon</div>
										</div>
									</div>
									<div class="monster-info-item">
										<span class="info-icon"></span>
										<div class="info-details">
											<div class="info-title">Colossal</div>
											<div class="info-subtitle">Titan</div>
										</div>
									</div>
									<div class="monster-info-item">
										<span class="info-icon"></span>
										<div class="info-details">
											<div class="info-title">Fiend</div>
											<div class="info-subtitle">Demon</div>
										</div>
									</div>
									<div class="monster-info-item">
										<span class="info-icon"></span>
										<div class="info-details">
											<div class="info-title">Wyrm</div>
											<div class="info-subtitle">Ancient</div>
										</div>
									</div>
								</div>

								<!-- Habitat Tab Content -->
								<div class="tab-pane" data-tab-content="habitat">
									<div class="monster-info-item">
										<span class="info-icon">🌲</span>
										<div class="info-details">
											<div class="info-title">Ancient Forest</div>
											<div class="info-subtitle">Floresta antiga com vegetação densa</div>
										</div>
									</div>
									<div class="monster-info-item">
										<span class="info-icon">🏔️</span>
										<div class="info-details">
											<div class="info-title">Elder's Recess</div>
											<div class="info-subtitle">Área vulcânica com energia elemental</div>
										</div>
									</div>
								</div>

								<!-- Behavior Tab Content -->
								<div class="tab-pane" data-tab-content="behavior">
									<div class="monster-info-item">
										<span class="info-icon">⚔️</span>
										<div class="info-details">
											<div class="info-title">Agressivo</div>
											<div class="info-subtitle">Ataca caçadores à vista</div>
										</div>
									</div>
									<div class="monster-info-item">
										<span class="info-icon">🔥</span>
										<div class="info-details">
											<div class="info-title">Elemental</div>
											<div class="info-subtitle">Usa ataques elementais poderosos</div>
										</div>
									</div>
								</div>

								<!-- Materials Tab Content -->
								<div class="tab-pane" data-tab-content="materials">
									<div class="materials-list">
										<h3 class="materials-title">Materiais Obtidos</h3>
										<ul class="materials-items">
											{monster.materials.map((material) => (
												<li class="material-item">{material}</li>
											))}
										</ul>
									</div>
									<div class="recommended-glaive">
										<h3 class="glaive-title">Insect Glaive Recomendado</h3>
										<p class="glaive-name">{monster.recommendedGlaive}</p>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</main>
	</div>
</Layout>

<style>
	.monster-page {
		min-height: 100vh;
		background-color: #eef4f6;
		background-image: url('https://www.figma.com/api/mcp/asset/e655ce98-4898-493b-8bfa-afb85850d1ff');
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
		background-attachment: fixed;
		position: relative;
	}

	.monster-page::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-color: #eef4f6;
		opacity: 0.6;
		z-index: 0;
	}

	/* Navbar Styles */
	.navbar {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		padding: 1.25rem 7.5rem;
	}

	.navbar-content {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 1.5rem;
	}

	.search-bar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex: 1;
		max-width: 400px;
		height: 60px;
		background-color: #eef4f6;
		border: 1px solid #b5c8d0;
		border-radius: 20px;
		padding: 0.75rem 1.5rem;
	}

	.search-input {
		flex: 1;
		border: none;
		background: none;
		font-size: 1.125rem;
		color: #0f191e;
		outline: none;
	}

	.search-input[readonly] {
		cursor: default;
		opacity: 0.8;
	}

	.search-button {
		background: none;
		border: none;
		color: #0f191e;
		cursor: pointer;
		padding: 0.25rem;
		border-radius: 4px;
		transition: background-color 0.3s ease;
	}

	.search-button:hover {
		background-color: rgba(15, 25, 30, 0.1);
	}

	.filter-button {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		background-color: #eef4f6;
		border: none;
		border-radius: 12px;
		padding: 0.75rem 1.25rem;
		font-size: 1.125rem;
		color: #0f191e;
		cursor: pointer;
		transition: all 0.3s ease;
		white-space: nowrap;
		width: 142px;
		justify-content: center;
	}

	.filter-button:hover {
		background-color: #d4e1e6;
		transform: translateY(-1px);
	}

	.brand {
		width: 267px;
		height: 200px;
	}

	.brand img {
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	/* Monster Content */
	.monster-content {
		position: relative;
		z-index: 1;
		padding-top: 220px;
		min-height: 1080px;
		padding-bottom: 286px;
	}

	.monster-layout {
		display: flex;
		flex-wrap: wrap;
		gap: 1.5rem;
		align-items: flex-start;
		justify-content: center;
	}

	.monster-left-column,
	.monster-right-column {
		flex: 1;
		min-width: 300px;
		max-width: 600px;
	}

	/* Monster Header */
	.monster-header {
		display: flex;
		align-items: center;
		padding: 0;
		margin-bottom: 1.5rem;
	}

	.monster-icon-large {
		background-color: #d4e1e6;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		padding: 1.3125rem;
		border-radius: 20px;
		width: 140px;
		height: 140px;
	}

	.monster-icon-large img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.monster-title-section {
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0;
	}

	.monster-title {
		font-family: 'Lato', sans-serif;
		font-size: 2.375rem;
		color: #0f191e;
		margin: 0;
		line-height: 1.6;
		white-space: nowrap;
	}

	/* Monster Description */
	.monster-description {
		padding: 1.5rem 0;
	}

	.monster-description p {
		font-family: 'rpg-awesome', sans-serif;
		font-size: 1rem;
		color: #0f191e;
		margin: 0;
		line-height: 1.6;
	}

	/* Monster Image */
	.monster-image-section {
		position: relative;
		isolation: isolate;
		margin-bottom: 3.375rem;
	}

	.monster-main-image {
		width: 100%;
		height: auto;
		aspect-ratio: 16/9;
		object-fit: cover;
		border-radius: 12px;
	}

	/* Monster Tags */
	.monster-tags {
		height: 85px;
		position: relative;
		width: 100%;
	}

	.monster-type-tag {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-family: 'rpg-awesome', sans-serif;
		color: #0f191e;
		position: absolute;
		top: 12px;
		left: 0;
		right: 0;
		justify-content: center;
	}

	.type-icon {
		font-size: 2.375rem;
		width: 61px;
		line-height: 1.6;
	}

	.type-name {
		font-size: 1rem;
		white-space: nowrap;
		line-height: 1.6;
	}

	/* Tabs */
	.tabs-container {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.tabs {
		display: flex;
		align-items: center;
		padding: 0;
	}

	.tab {
		flex: 1;
		background-color: white;
		border: none;
		border-radius: 20px;
		padding: 1rem;
		font-family: 'Lato', sans-serif;
		font-size: 1.3125rem;
		color: #0f191e;
		cursor: pointer;
		transition: all 0.3s ease;
		text-align: center;
	}

	.tab:hover {
		background-color: #f7fbfc;
	}

	.tab.is-active {
		background-color: white;
		box-shadow: 0 2px 8px rgba(15, 25, 30, 0.1);
	}

	/* Tab Content */
	.tab-content {
		background-color: white;
		border-radius: 12px;
		padding: 1rem;
		min-height: 400px;
	}

	.tab-pane {
		display: none;
		flex-direction: column;
		gap: 1.5rem;
		font-family: 'rpg-awesome', sans-serif;
		color: #0f191e;
		text-align: left;
	}

	.tab-pane.is-active {
		display: flex;
	}

	.monster-info-item {
		display: flex;
		align-items: center;
		gap: 1rem;
		width: 100%;
		max-width: 828px;
	}

	.info-icon {
		font-size: 2.375rem;
		width: 61px;
		line-height: 1.6;
		display: flex;
		justify-content: center;
	}

	.info-details {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		white-space: nowrap;
	}

	.info-title {
		font-size: 1.75rem;
		line-height: 1.6;
	}

	.info-subtitle {
		font-size: 1rem;
		line-height: 1.6;
		opacity: 0.8;
	}

	/* Materials Tab Specific Styles */
	.materials-list {
		margin-bottom: 2rem;
	}

	.materials-title {
		font-size: 1.5rem;
		margin-bottom: 1rem;
		color: #0f191e;
	}

	.materials-items {
		list-style: none;
		padding: 0;
	}

	.material-item {
		padding: 0.5rem 0;
		border-bottom: 1px solid #eef4f6;
		font-size: 1rem;
	}

	.material-item:last-child {
		border-bottom: none;
	}

	.recommended-glaive {
		background-color: #f7fbfc;
		padding: 1rem;
		border-radius: 8px;
		border-left: 4px solid #3273dc;
	}

	.glaive-title {
		font-size: 1.125rem;
		margin-bottom: 0.5rem;
		color: #0f191e;
	}

	.glaive-name {
		font-size: 1.25rem;
		font-weight: 600;
		color: #3273dc;
	}

	/* Responsive Design */
	@media screen and (max-width: 768px) {
		.navbar {
			padding: 1rem 2rem;
			flex-direction: column;
			gap: 1rem;
		}

		.navbar-content {
			flex-direction: column;
			width: 100%;
		}

		.search-bar {
			max-width: 100%;
		}

		.monster-content {
			padding-top: 180px;
		}

		.monster-layout {
			flex-direction: column;
			gap: 2rem;
		}

		.monster-left-column,
		.monster-right-column {
			max-width: 100%;
		}

		.monster-header {
			flex-direction: column;
			gap: 1rem;
			text-align: center;
		}

		.monster-title {
			font-size: 2rem;
			white-space: normal;
		}

		.tabs {
			flex-direction: column;
			gap: 0.5rem;
		}

		.tab {
			font-size: 1.125rem;
		}
	}

	@media screen and (max-width: 480px) {
		.navbar {
			padding: 1rem;
		}

		.monster-content {
			padding-top: 140px;
		}

		.monster-title {
			font-size: 1.5rem;
		}

		.monster-icon-large {
			width: 120px;
			height: 120px;
		}

		.tab {
			font-size: 1rem;
			padding: 0.75rem;
		}

		.info-icon {
			font-size: 2rem;
		}

		.info-title {
			font-size: 1.5rem;
		}

		.info-subtitle {
			font-size: 0.875rem;
		}
	}

	/* Accessibility */
	@media (prefers-reduced-motion: reduce) {
		.tab,
		.filter-button,
		.search-button {
			transition: none;
		}
		
		.filter-button:hover {
			transform: none;
		}
	}
</style>

<script>
</script>
